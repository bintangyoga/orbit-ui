{
  "name": "orbit-ui",
  "version": "0.1.1",
  "description": "A beautiful, glassmorphic React component library CLI — like shadcn/ui but with gradient depth effects",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspace=packages/cli",
    "docs": "npm run dev --workspace=packages/docs",
    "lint": "eslint packages/*/src"
  },
  "keywords": [
    "react",
    "components",
    "tailwind",
    "glassmorphism",
    "cli"
  ],
  "license": "MIT"
}
